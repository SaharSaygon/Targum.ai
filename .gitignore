# Secrets & credentials — NEVER commit these
.env
credentials.json
token.json

# Per-user config (non-secret, but machine-specific) — committed shape lives in
# config.example.json; the real one stays local.
config.json

# Python bytecode cache — auto-generated, not source code
__pycache__/
*.pyc

# Virtual environment — too large, recreated via requirements.txt
.venv/

# Log files & cost ledgers
*.log
*.jsonl

# macOS metadata files (for when you switch to Mac)
.DS_Store
logs/

# Personal build logs / planning — kept locally, not for the public repo
Documentation/day_1_checklist.md
Documentation/day_2_checklist.md
Documentation/hebrew_translator_project_plan.md
